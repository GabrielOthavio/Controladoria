# =============================================================================
# Arquivo de exemplo para configuração de ambiente do Sistema Controladoria
# -----------------------------------------------------------------------------
# Como usar:
#   1. Copie este arquivo para `.env` na raiz do projeto:
#        cp .env.example .env
#   2. Substitua cada placeholder pelos valores reais do seu ambiente.
#   3. NUNCA versione o arquivo `.env` (ele já está listado no .gitignore).
# =============================================================================


# -----------------------------------------------------------------------------
# Django: chave secreta da aplicação
# -----------------------------------------------------------------------------
# Gere uma chave nova com o comando abaixo e cole o resultado aqui:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cole_aqui_a_chave_gerada_pelo_comando_acima


# -----------------------------------------------------------------------------
# Django: hosts autorizados (separados por vírgula, sem espaços)
# -----------------------------------------------------------------------------
ALLOWED_HOSTS=127.0.0.1,localhost


# -----------------------------------------------------------------------------
# Django: modo de depuração
# -----------------------------------------------------------------------------
# Use True apenas em ambiente local de desenvolvimento.
# Em produção, deve ser sempre False.
DEBUG=True


# -----------------------------------------------------------------------------
# django-encrypted-model-fields: chave de criptografia de campos sensíveis
# -----------------------------------------------------------------------------
# Gere uma chave Fernet nova com o comando abaixo e cole o resultado aqui:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# ATENÇÃO: uma vez gerada e usada para criptografar dados, esta chave NÃO pode
# ser substituída sem perder o acesso aos dados já persistidos. Guarde-a com
# o mesmo cuidado dispensado a credenciais de banco de dados.
FIELD_ENCRYPTION_KEY=cole_aqui_a_chave_fernet_gerada_pelo_comando_acima


# -----------------------------------------------------------------------------
# Credenciais do banco de dados PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=nome_do_banco_de_dados
DB_USER=usuario_do_banco
DB_PASSWORD=senha_do_usuario
DB_HOST=localhost
DB_PORT=5432


# -----------------------------------------------------------------------------
# API interna consumida pelo sync-backend (NestJS) do app móvel de campo
# -----------------------------------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Segredo compartilhado — deve ser IDÊNTICO ao MOBILE_SYNC_API_KEY configurado
# no .env do mobile/sync-backend. Nunca embutir no app mobile (só nos backends).
MOBILE_SYNC_API_KEY=cole_aqui_a_chave_gerada_pelo_comando_acima

# IPs autorizados a chamar a API interna (o(s) host(s) do sync-backend),
# separados por vírgula. Deixe em branco para não restringir por IP (não
# recomendado fora de desenvolvimento local).
MOBILE_SYNC_ALLOWED_IPS=127.0.0.1
